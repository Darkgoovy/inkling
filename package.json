{
  "name": "inkling",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Cartes de lecture — réviser des livres par petites cartes de ~10 min, avec progression et gamification.",
  "scripts": {
    "build:index": "python build_books_index.py --books-dir public/books --output public/books.json",
    "prebuild": "npm run build:index",
    "predev": "npm run build:index",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^11.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  }
}
